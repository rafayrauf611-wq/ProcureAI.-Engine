# ==========================================
# Django Core Settings
# ==========================================
DJANGO_SECRET_KEY=your-super-secret-key-do-not-share
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,api.youragency.com

# ==========================================
# Database Configuration (PostgreSQL)
# ==========================================
DB_NAME=procurement_db
DB_USER=postgres
DB_PASSWORD=secure_database_password
DB_HOST=db
DB_PORT=5432

# ==========================================
# Celery & Redis (Async Task Queue)
# ==========================================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ==========================================
# AI Abstraction Layer
# ==========================================
# Options: odysseus, openai, azure
AI_PROVIDER=odysseus 

# For local Odysseus setup:
AI_BASE_URL=http://host.docker.internal:8000/v1
AI_API_KEY=local-dev-key
AI_MODEL_NAME=local-model-name

# For OpenAI fallback:
# AI_BASE_URL=https://api.openai.com/v1
# AI_API_KEY=sk-...
